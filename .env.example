POSTGRES_PASSWORD=loaded_dev
NEXT_PUBLIC_API_URL=http://localhost:9000

# Host ports (loaded uses 9000-9999 for the API and 4000-4999 for the frontend).
BACKEND_PORT=9000
FRONTEND_PORT=4000

# CORS — comma-separated list of allowed origins.
# Leave empty to allow all origins (dev only — lock this down in production).
# Example: ALLOWED_ORIGINS=https://app.loaded.com,https://admin.loaded.com
ALLOWED_ORIGINS=

# Alpaca Paper account (https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=

# Alpaca Real Money account (https://app.alpaca.markets/live/dashboard/overview)
# Leave empty to disable real money trading
ALPACA_REAL_API_KEY=
ALPACA_REAL_SECRET_KEY=

# Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# JWT Auth (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Default admin user (seeded on first startup if both are set)
ADMIN_EMAIL=admin@loaded.app
ADMIN_PASSWORD=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
FRONTEND_URL=http://localhost:4000

# Auth cookies. Set COOKIE_SECURE=true in production (HTTPS).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
